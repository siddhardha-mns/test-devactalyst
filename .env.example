# ─── Contact Form ────────────────────────────────────────────────────────────
# Google Apps Script Web App URL — used SERVER-SIDE only (api/contact.js).
# Never expose this in client-side code.
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── Site / SEO ───────────────────────────────────────────────────────────────
# Canonical production URL (no trailing slash). Used by sitemap/robots generation.
VITE_SITE_URL=https://your-production-domain.com
